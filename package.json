{
  "name": "solid-mobile",
  "version": "0.1.0",
  "description": "50+ mobile UI components for Solid.js — theme system, i18n, dark mode, tree-shakable, TypeScript.",
  "type": "module",
  "license": "MIT",
  "author": "LXG19961206",
  "homepage": "https://lxg19961206.github.io/SolidMobile/",
  "repository": {
    "type": "git",
    "url": "https://github.com/LXG19961206/SolidMobile"
  },
  "keywords": [
    "solid-js",
    "solidjs",
    "mobile",
    "component-library",
    "ui",
    "ui-components",
    "ui-library",
    "vant",
    "typescript",
    "dark-mode",
    "i18n",
    "theme",
    "solidjs-components",
    "mobile-ui",
    "touch"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/solid-mobile.css",
    "./icons": {
      "types": "./dist/components/Icon/icons/index.d.ts",
      "import": "./dist/components/Icon/icons/index.js"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite serve playground --open",
    "build": "vite build && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist --declaration",
    "build:local": "BUILD_LOCAL=1 vite build && tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist-dev --declaration",
    "build:docs": "node scripts/merge-doc-i18n.cjs && vite build --mode docs && cp src/i18n/dictionaries.ts.backup src/i18n/dictionaries.ts",
    "dev:docs": "vite --mode docs",
    "dev:docs:dist": "npm run build:local && USE_DIST=1 vite --mode docs",
    "preview": "vite preview playground",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.16.0",
    "eslint-plugin-solid": "^0.14.5",
    "happy-dom": "^15.11.7",
    "prettier": "^3.4.2",
    "prismjs": "^1.30.0",
    "solid-js": "^1.9.4",
    "typescript": "^5.7.2",
    "vite": "^7.3.5",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@testing-library/user-event": "^14.6.1"
  }
}
